@page "/register"
@using System.Net.Http.Json
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using System.ComponentModel.DataAnnotations
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Register - Ashen Light</PageTitle>

<div class="signin-container">
    <div class="signin-background">
        <div class="signin-card">
            <h1 class="signin-title">Create an account</h1>

            <EditForm Model="@registerModel" OnValidSubmit="@HandleRegister" class="signin-form">
                <DataAnnotationsValidator />
                <ValidationSummary/>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="validation-message" style="color: #b00020; font-weight:600">@errorMessage</div>
                }

                <div class="form-group">
                    <input @bind="registerModel.Username"
                           class="form-input"
                           placeholder="Username"
                           aria-label="Username" />
                </div>

                <div class="form-group">
                    <input @bind="registerModel.Email"
                           class="form-input"
                           placeholder="Email"
                           aria-label="Email" />
                </div>

                <div class="form-group">
                    <input type="password"
                           @bind="registerModel.Password"
                           class="form-input"
                           placeholder="Password"
                           aria-label="Password" />
                </div>

                <div class="form-group">
                    <input type="password"
                           @bind="registerModel.ConfirmPassword"
                           class="form-input"
                           placeholder="Confirm Password"
                           aria-label="Confirm Password" />
                </div>

                <button type="submit" class="btn-login" disabled="@isLoading">@((isLoading) ? "Registering..." : "Register")</button>
            </EditForm>

            <div class="signin-footer">
                <a href="/forgot-password" class="signin-link">Forgot password?</a>
                <a href="/signin" class="signin-link">Already have an account?</a>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterModel registerModel = new();
    private bool isLoading = false;
    private string errorMessage = string.Empty;

    private async Task HandleRegister()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;

            if (registerModel.Password != registerModel.ConfirmPassword)
            {
                errorMessage = "Passwords do not match.";
                return;
            }

            var httpClient = HttpClientFactory.CreateClient("Api");

            var response = await httpClient.PostAsJsonAsync("api/auth/register", registerModel);

            if (response.IsSuccessStatusCode)
            {
                var registerResponse = await response.Content.ReadFromJsonAsync<RegisterResponse>();

                if (registerResponse != null && !string.IsNullOrEmpty(registerResponse.Token))
                {
                    var httpContext = HttpContextAccessor.HttpContext;
                    if (httpContext != null)
                    {
                        httpContext.Session.SetString("JwtToken", registerResponse.Token);

                        var claims = new List<Claim>
                        {
                            new Claim(ClaimTypes.NameIdentifier, registerResponse.UserId.ToString()),
                            new Claim(ClaimTypes.Name, registerResponse.Username),
                            new Claim(ClaimTypes.Email, registerResponse.Email ?? string.Empty),
                            new Claim("Avatar", registerResponse.Avatar ?? string.Empty),
                            new Claim("Gender", registerResponse.Gender.ToString()),
                        };

                        if (registerResponse.Roles != null)
                        {
                            foreach (var role in registerResponse.Roles)
                            {
                                claims.Add(new Claim(ClaimTypes.Role, role));
                            }
                        }

                        var claimsIdentity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
                        var claimsPrincipal = new ClaimsPrincipal(claimsIdentity);

                        await httpContext.SignInAsync(
                            CookieAuthenticationDefaults.AuthenticationScheme,
                            claimsPrincipal,
                            new AuthenticationProperties
                            {
                                IsPersistent = true,
                                ExpiresUtc = DateTimeOffset.UtcNow.AddHours(12)
                            });

                        Navigation.NavigateTo("/", forceLoad: true);
                    }
                }
                else
                {
                    errorMessage = "Registration failed. Please try again.";
                }
            }
            else
            {
                var errorResponse = await response.Content.ReadAsStringAsync();
                // Prefer server-provided message if available
                errorMessage = string.IsNullOrWhiteSpace(errorResponse) ? "Registration failed. Please check your details." : errorResponse;
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred during registration. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    public class RegisterModel
    {
        [Required(ErrorMessage = "Username is required")]
        public string Username { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email address")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required")]
        [DataType(DataType.Password)]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Confirm Password is required")]
        [DataType(DataType.Password)]
        [Compare("Password", ErrorMessage = "Passwords do not match")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }

    public class RegisterResponse
    {
        public string Token { get; set; } = string.Empty;
        public Guid UserId { get; set; }
        public string Username { get; set; } = string.Empty;
        public string? Email { get; set; }
        public string? Avatar { get; set; }
        public byte Gender { get; set; }
        public List<string>? Roles { get; set; }
    }
}
