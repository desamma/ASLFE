@page
@model FE.Pages.Inventory.IndexModel
@{
    ViewData["Title"] = "My Inventory";
}

<div class="inventory-container">
    <!-- Inventory Header -->
    <section class="inventory-header">
        <div class="inventory-header-content">
            <h1 class="inventory-title">My Inventory</h1>
            <p class="inventory-subtitle">View all your collected items and equipment</p>
        </div>
    </section>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
        <div class="back-link-section">
            <a href="/Profile" class="back-link">Back to Profile</a>
        </div>
    }
    else
    {
        @if (Model.UserItems.Count == 0)
        {
            <div class="empty-inventory">
                <div class="empty-state">
                    <div class="empty-icon">??</div>
                    <h2>Your inventory is empty</h2>
                    <p>Start collecting items by playing the game or shopping!</p>
                    <a href="/Shop" class="btn btn-primary">Go to Shop</a>
                </div>
            </div>
        }
        else
        {
            <!-- Filter/Sort Section -->
            <section class="inventory-controls">
                <div class="controls-container">
                    <div class="search-box">
                        <input type="text" id="itemSearch" placeholder="Search items..." class="search-input" />
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class="search-icon">
                            <circle cx="11" cy="11" r="8"></circle>
                            <path d="m21 21-4.35-4.35"></path>
                        </svg>
                    </div>
                    <div class="filter-buttons">
                        <button class="filter-btn active" data-filter="all">All</button>
                        <button class="filter-btn" data-filter="weapon">Weapon</button>
                        <button class="filter-btn" data-filter="armor">Armor</button>
                        <button class="filter-btn" data-filter="accessory">Accessory</button>
                        <button class="filter-btn" data-filter="consumable">Consumable</button>
                    </div>
                </div>
            </section>

            <!-- Inventory Grid -->
            <section class="inventory-grid-section">
                <div class="inventory-grid" id="inventoryGrid">
                    @foreach (var item in Model.UserItems)
                    {
                        <div class="inventory-item" data-item-id="@item.ItemId" data-item-type="@item.Type.ToLower()" data-item-name="@item.Name.ToLower()">
                            <div class="item-card">
                                <!-- Item Image -->
                                <div class="item-image-wrapper">
                                    <img src="@item.ImagePath" alt="@item.Name" class="item-image" />
                                    <span class="rarity-badge rarity-@item.Rarity.ToLower().Replace(" ", "-")">
                                        @item.Rarity
                                    </span>
                                    <div class="quantity-badge">@item.Quantity</div>
                                </div>

                                <!-- Item Info -->
                                <div class="item-info">
                                    <h3 class="item-name">@item.Name</h3>
                                    <p class="item-type">@item.Type</p>
                                </div>

                                <!-- Delivery Status Badge -->
                                @if (item.QuantityPending > 0)
                                {
                                    <div class="delivery-status pending">
                                        <span class="status-badge">Pending</span>
                                    </div>
                                }
                                else if (item.IsDeliveredToGame)
                                {
                                    <div class="delivery-status delivered">
                                        <span class="status-badge">Delivered</span>
                                    </div>
                                }

                                <!-- Hover Tooltip -->
                                <div class="item-tooltip">
                                    <div class="tooltip-header">
                                        <h4 class="tooltip-title">@item.Name</h4>
                                        <span class="tooltip-rarity rarity-@item.Rarity.ToLower().Replace(" ", "-")">
                                            @item.Rarity
                                        </span>
                                    </div>

                                    <div class="tooltip-type">
                                        <strong>Type:</strong> @item.Type
                                    </div>

                                    <div class="tooltip-description">
                                        @item.Description
                                    </div>

                                    <div class="tooltip-quantity">
                                        <strong>Total Quantity:</strong> @item.Quantity
                                    </div>

                                    <div class="tooltip-delivery">
                                        <strong>Delivered:</strong> @item.QuantityDelivered / @item.Quantity
                                        @if (item.QuantityPending > 0)
                                        {
                                            <div class="pending-info">Pending: @item.QuantityPending</div>
                                        }
                                    </div>

                                    @if (item.IsDeliveredToGame && item.DeliveredToGameAt.HasValue)
                                    {
                                        <div class="tooltip-delivery-date">
                                            <strong>Delivered On:</strong> @item.DeliveredToGameAt.Value.ToString("MMM dd, yyyy HH:mm")
                                        </div>
                                    }

                                    <div class="tooltip-created-date">
                                        <strong>Acquired:</strong> @item.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <!-- Inventory Stats -->
            <section class="inventory-stats">
                <div class="stats-container">
                    <div class="stat-item">
                        <span class="stat-label">Total Items</span>
                        <span class="stat-value">@Model.UserItems.Count</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Total Quantity</span>
                        <span class="stat-value">@Model.UserItems.Sum(x => x.Quantity)</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Delivered</span>
                        <span class="stat-value">@Model.UserItems.Sum(x => x.QuantityDelivered)</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Pending</span>
                        <span class="stat-value">@Model.UserItems.Sum(x => x.QuantityPending)</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Rarity Count</span>
                        <span class="stat-value">@Model.UserItems.Select(x => x.Rarity).Distinct().Count()</span>
                    </div>
                </div>
            </section>
        }

        <!-- Back Button -->
        <div class="inventory-footer">
            <a href="/Profile" class="btn btn-secondary">Back to Profile</a>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/inventory-index.js"></script>
}
