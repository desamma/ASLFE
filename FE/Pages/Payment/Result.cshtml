@page
@model FE.Pages.Payment.ResultModel
@{
    ViewData["Title"] = "Payment Result";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/payment.css" asp-append-version="true" />
}

<div class="payment-wrapper">
    <div class="page-header">
        <a href="/Payment" class="back-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 12H5M5 12l7 7M5 12l7-7" />
            </svg>
            Back to Top Up
        </a>
        <div class="page-title">Payment <span>Result</span></div>
    </div>

    <div id="result-section">
        <div class="result-wrap">
            <div style="width:48px;height:48px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin 0.8s linear infinite;margin:0 auto 24px"></div>
            <div style="color:var(--text-muted);font-size:14px">Checking payment result...</div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.API_BASE = '/payment-proxy';
    </script>
    <script src="~/js/payment.js" asp-append-version="true"></script>
}
