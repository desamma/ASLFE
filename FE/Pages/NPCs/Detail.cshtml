@page "{id:guid}"
@model DetailModel
@{
    ViewData["Title"] = Model.NPC?.Name ?? "NPC Details";
}

<div class="detail-container">
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
        <div class="back-link-section">
            <a href="/NPCs" class="back-link">Back to NPCs</a>
        </div>
    }
    else if (Model.NPC != null)
    {
        <!-- Back Link -->
        <div class="back-link-section">
            <a href="/NPCs" class="back-link">Back to NPCs</a>
        </div>

        <!-- Detail Header -->
        <section class="detail-header">
            <div class="detail-header-content">
                <div class="breadcrumb">
                    <span class="breadcrumb-item"><a href="/NPCs">NPCs</a></span>
                    <span class="breadcrumb-separator">/</span>
                    <span class="breadcrumb-item">@Model.NPC.NPCType</span>
                    <span class="breadcrumb-separator">/</span>
                    <span class="breadcrumb-item active">@Model.NPC.Name</span>
                </div>
                <h1 class="detail-title">@Model.NPC.Name</h1>
            </div>
        </section>

        <!-- Main Content -->
        <section class="detail-content">
            <div class="detail-grid">
                <!-- Left Column: Image -->
                <div class="detail-image-section">
                    <div class="image-wrapper">
                        <img src="@Model.NPC.ImagePath" alt="@Model.NPC.Name" class="detail-image" />
                        <span class="type-badge-large type-@Model.NPC.NPCType.ToLower().Replace(" ", "-")">
                            @Model.NPC.DisplayType
                        </span>
                    </div>
                </div>

                <!-- Right Column: Details -->
                <div class="detail-info-section">
                    <!-- NPC Type -->
                    <div class="info-group">
                        <h3 class="info-title">Type</h3>
                        <p class="info-value">@Model.NPC.DisplayType</p>
                    </div>

                    <!-- Location -->
                    @if (!string.IsNullOrEmpty(Model.NPC.Location))
                    {
                        <div class="info-group">
                            <h3 class="info-title">Location</h3>
                            <p class="info-value">
                                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" xmlns="http://www.w3.org/2000/svg"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <path d="M12 21C15.5 17.4 19 14.1764 19 10.2C19 6.22355 15.866 3 12 3C8.13401 3 5 6.22355 5 10.2C5 14.1764 8.5 17.4 12 21Z" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path> <path d="M12 12C13.1046 12 14 11.1046 14 10C14 8.89543 13.1046 8 12 8C10.8954 8 10 8.89543 10 10C10 11.1046 10.8954 12 12 12Z" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path> </g></svg>
                                @Model.NPC.Location
                                </p>
                        </div>
                    }

                    <!-- Description -->
                    @if (!string.IsNullOrEmpty(Model.NPC.Description))
                    {
                        <div class="info-group">
                            <h3 class="info-title">Description</h3>
                            <p class="info-description">@Model.NPC.Description</p>
                        </div>
                    }

                    <!-- Created Date -->
                    <div class="info-group">
                        <h3 class="info-title">Created</h3>
                        <p class="info-value">@Model.NPC.CreatedDate.ToString("dd/MM/yyyy")</p>
                    </div>

                    <!-- Updated Date -->
                    @if (Model.NPC.UpdatedDate.HasValue)
                    {
                        <div class="info-group">
                            <h3 class="info-title">Last Updated</h3>
                            <p class="info-value">@Model.NPC.UpdatedDate.Value.ToString("dd/MM/yyyy")</p>
                        </div>
                    }
                </div>
            </div>
        </section>
    }
</div>
