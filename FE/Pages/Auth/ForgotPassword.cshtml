@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="signin-container">
    <div class="signin-background">
        <div class="signin-card">
            <h1 class="signin-title">Forgot Password</h1>

            <div class="form-description">
                <p>Enter your email address and we'll send you a link to reset your password.</p>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="validation-message" style="color: green; border-color: green;">@TempData["Success"]</div>
            }

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="validation-message">@Model.ErrorMessage</div>
            }

            <form method="post" class="signin-form">
                <div asp-validation-summary="All" class="text-danger"></div>

                <input asp-for="Input.Email" class="form-input" placeholder="Email" />
                <span asp-validation-for="Input.Email" class="validation-error"></span>

                <button type="submit" class="btn-login">
                    Send Reset Link
                </button>
            </form>

            <div class="signin-footer">
                <a href="/Auth/Login" class="signin-link">Back to Login</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
