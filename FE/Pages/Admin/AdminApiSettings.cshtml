@page
@model FE.Pages.Admin.AdminApiSettingsModel
@{
    ViewData["Title"] = "API Configurations";
}

<style>
    /* CSS Tùy chỉnh riêng cho trang API Settings */
    .api-card {
        background-color: #18181b;
        border: 1px solid #27272a;
        border-radius: 16px;
        padding: 30px;
        margin-bottom: 25px;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .api-card:hover {
        border-color: #3f3f46;
        box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5);
        transform: translateY(-2px);
    }

    /* Hiệu ứng viền sáng mờ ở góc thẻ */
    .gemini-card::before {
        content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 4px;
        background: linear-gradient(90deg, #8b5cf6, #d946ef);
    }

    .colab-card::before {
        content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 4px;
        background: linear-gradient(90deg, #3b82f6, #06b6d4);
    }

    .api-header {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .gemini-text { color: #c084fc; }
    .colab-text { color: #60a5fa; }

    .api-desc {
        color: #a1a1aa;
        font-size: 0.85rem;
        margin-bottom: 20px;
        line-height: 1.5;
    }

    .api-input-wrapper {
        position: relative;
    }

    .api-textarea {
        width: 100%;
        background-color: #09090b;
        border: 1px solid #27272a;
        color: #f4f4f5;
        border-radius: 8px;
        padding: 16px;
        font-family: 'Consolas', 'Courier New', monospace;
        font-size: 0.9rem;
        resize: vertical;
        min-height: 100px;
        transition: all 0.2s ease;
    }

    .api-textarea:focus {
        outline: none;
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
        background-color: #0f0f13;
    }

    .btn-save-config {
        background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
        color: white;
        border: none;
        padding: 14px 32px;
        border-radius: 8px;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .btn-save-config:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(99, 102, 241, 0.4);
    }
    
    .btn-save-config:active {
        transform: translateY(0);
    }
</style>

<div class="container-fluid admin-wrapper mt-4 mb-5" style="max-width: 900px; margin: 0 auto;">
    <div class="d-flex justify-content-between align-items-center mb-4" style="border-bottom: 2px solid #333; padding-bottom: 15px;">
        <h2 class="admin-title m-0 border-0 p-0">System API Configurations</h2>
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert d-flex align-items-center gap-2" 
             style="background: @(Model.IsSuccess ? "rgba(16, 185, 129, 0.1)" : "rgba(239, 68, 68, 0.1)"); 
                    color: @(Model.IsSuccess ? "#34d399" : "#f87171"); 
                    border: 1px solid @(Model.IsSuccess ? "rgba(16, 185, 129, 0.2)" : "rgba(239, 68, 68, 0.2)"); 
                    border-radius: 12px; padding: 16px; margin-bottom: 25px; font-weight: 500;">
            @if (Model.IsSuccess)
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16"><path d="M10.97 4.97a.75.75 0 0 1 1.07 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425a.267.267 0 0 1 .02-.022z"/></svg>
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16"><path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/><path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 4.995z"/></svg>
            }
            @Model.Message
        </div>
    }

    <form method="post">
        <div class="api-card gemini-card">
            <div class="api-header gemini-text">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M2.866 14.85c-.078.444.36.791.746.593l4.39-2.256 4.389 2.256c.386.198.824-.149.746-.592l-.83-4.73 3.522-3.356c.33-.314.16-.888-.282-.95l-4.898-.696L8.465.792a.513.513 0 0 0-.927 0L5.354 5.12l-4.898.696c-.441.062-.612.636-.283.95l3.523 3.356-.83 4.73zm4.905-2.767-3.686 1.894.694-3.957a.565.565 0 0 0-.163-.505L1.71 6.745l4.052-.576a.525.525 0 0 0 .393-.288L8 2.223l1.847 3.658a.525.525 0 0 0 .393.288l4.052.575-2.906 2.77a.565.565 0 0 0-.163.506l.694 3.957-3.686-1.894a.503.503 0 0 0-.461 0z"/>
                </svg>
                Google Gemini API
            </div>
            <p class="api-desc">Used for generating dynamic NPC interactions, game lore, and intelligent system responses.</p>
            
            <div class="api-input-wrapper">
                <textarea asp-for="Settings.GeminiApiKey" class="api-textarea" placeholder="Paste your Gemini API Key here (e.g. AIzaSyB8ulDIQ8dUf...)"></textarea>
            </div>
        </div>

        <div class="api-card colab-card">
            <div class="api-header colab-text">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M10.478 1.647a.5.5 0 1 0-.956-.294l-4 13a.5.5 0 0 0 .956.294l4-13zM4.854 4.146a.5.5 0 0 1 0 .708L1.707 8l3.147 3.146a.5.5 0 0 1-.708.708l-3.5-3.5a.5.5 0 0 1 0-.708l3.5-3.5a.5.5 0 0 1 .708 0zm6.292 0a.5.5 0 0 0 0 .708L14.293 8l-3.147 3.146a.5.5 0 0 0 .708.708l3.5-3.5a.5.5 0 0 0 0-.708l-3.5-3.5a.5.5 0 0 0-.708 0z"/>
                </svg>
                Google Colab Endpoint
            </div>
            <p class="api-desc">Ngrok/Cloudflare tunnel URL from your running Colab notebook for local Python model execution.</p>
            
            <div class="api-input-wrapper">
                <textarea asp-for="Settings.ColabApiUrl" class="api-textarea" placeholder="Paste your Colab URL here (e.g. https://auction-jpg-vatican-remained.trycloudflare.com)"></textarea>
            </div>
        </div>

        <div class="d-flex justify-content-end mt-2">
            <button type="submit" class="btn-save-config">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M2 1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H9.5a1 1 0 0 0-1 1v7.293l2.646-2.647a.5.5 0 0 1 .708.708l-3.5 3.5a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L7.5 9.293V2a2 2 0 0 1 2-2H14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h2.5a.5.5 0 0 1 0 1H2z"/>
                </svg>
                Save Configurations
            </button>
        </div>
    </form>
</div>