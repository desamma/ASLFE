@page
@model FE.Pages.Admin.AdminApiSettingsModel
@{
    ViewData["Title"] = "API Configurations";
}

<div class="container-fluid admin-wrapper mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4" style="border-bottom: 2px solid #333; padding-bottom: 15px;">
        <h2 class="admin-title m-0 border-0 p-0">System API Manager</h2>
        <button class="btn-primary-custom" type="button" onclick="openCreateModal()" style="background-color: #6366f1; color: white; border: none; border-radius: 6px; padding: 8px 16px; font-weight: 600; box-shadow: 0 4px 10px rgba(99, 102, 241, 0.3);">
            + Add New API
        </button>
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert" style="background: @(Model.IsSuccess ? "rgba(16, 185, 129, 0.15)" : "rgba(239, 68, 68, 0.15)"); color: @(Model.IsSuccess ? "#10b981" : "#f87171"); border: 1px solid @(Model.IsSuccess ? "rgba(16, 185, 129, 0.3)" : "rgba(239, 68, 68, 0.3)"); border-radius: 8px; margin-bottom: 20px; font-weight: 500;">
            @Model.Message
        </div>
    }

    <div class="table-responsive">
        <table class="admin-table">
            <thead>
                <tr>
                    <th style="width: 35%;">Gemini API Key</th>
                    <th style="width: 35%;">Colab Endpoint URL</th>
                    <th style="width: 15%;">Last Updated</th>
                    <th style="width: 15%;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.SettingsList.Count == 0)
                {
                    <tr>
                        <td colspan="4" style="color: #6b7280; padding: 30px; text-align: center;">No API configurations found. Click "+ Add New API" to create one.</td>
                    </tr>
                }
                @foreach (var item in Model.SettingsList)
                {
                    <tr>
                        <td style="color: #c084fc; font-family: monospace; font-size: 0.9rem;">
                            @(string.IsNullOrEmpty(item.GeminiApiKey) ? "N/A" : (item.GeminiApiKey.Length > 30 ? item.GeminiApiKey.Substring(0, 30) + "..." : item.GeminiApiKey))
                        </td>
                        <td style="color: #60a5fa; font-family: monospace; font-size: 0.9rem;">
                            @(string.IsNullOrEmpty(item.ColabApiUrl) ? "N/A" : item.ColabApiUrl)
                        </td>
                        <td style="color: #9ca3af; font-size: 0.85rem;">@item.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <div class="d-flex justify-content-center">
                                <form method="post" asp-page-handler="Delete" class="m-0" onsubmit="return confirm('Are you sure you want to delete this API config?');">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="action-btn" style="background-color: transparent; border: 1px solid #ef4444; color: #ef4444; border-radius: 6px; padding: 6px 16px; font-weight: 600; transition: 0.2s;" onmouseover="this.style.backgroundColor='rgba(239, 68, 68, 0.1)'" onmouseout="this.style.backgroundColor='transparent'">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="custom-modal-overlay" id="createModal">
    <div class="custom-modal">
        <form method="post" asp-page-handler="Create" class="m-0">
            <div class="modal-header-dark">
                <h5 class="modal-title">Add New API Configuration</h5>
                <button type="button" class="btn-close-custom" onclick="closeCreateModal()">✖</button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-custom">
                    <label class="form-label-custom" style="color: #c084fc; display: flex; align-items: center; gap: 8px; font-size: 0.75rem; letter-spacing: 0.5px; font-weight: 700; margin-bottom: 6px;">
                        ✨ GEMINI API KEY
                    </label>
                    <input type="text" name="geminiKey" class="dark-input" placeholder="AIzaSyB8ulDIQ8dUf..." style="font-family: monospace;" autocomplete="off" spellcheck="false" />
                </div>
                <div class="mb-custom">
                    <label class="form-label-custom" style="color: #60a5fa; display: flex; align-items: center; gap: 8px; font-size: 0.75rem; letter-spacing: 0.5px; font-weight: 700; margin-bottom: 6px;">
                        🚀 COLAB ENDPOINT URL
                    </label>
                    <input type="text" name="colabUrl" class="dark-input" placeholder="https://..." style="font-family: monospace;" autocomplete="off" spellcheck="false" />
                </div>
            </div>
            <div class="modal-footer-dark">
                <button type="submit" class="btn-save-modal">Save API</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openCreateModal() { document.getElementById('createModal').classList.add('show'); }
        function closeCreateModal() { document.getElementById('createModal').classList.remove('show'); }
    </script>
}