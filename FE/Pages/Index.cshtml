@page
@model IndexModel
@{
    ViewData["Title"] = "Homepage";
}

<div class="game-intro-container">
    <!-- Hero Section -->
    <section class="hero-section">
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="hero-bottom-left">
                <h1 class="hero-title">Begin your journey now!</h1>
                <p class="hero-subtitle">
                    The world of <strong>Ashen Light</strong> has appear right front you<br />
                    — Join and fend off powerful enemies.
                </p>
                <a href="#intro" class="learn-more">Learn How To Play</a>
            </div>

            <div class="hero-bottom-right">
                <a href="/Download" class="cta-button">Download Now</a>
            </div>
        </div>
        <div class="hero-image">
            <img src="@Model.ResolveImageUrl("images/startscreemas.png")" alt="Monster Hunter Mask" />
        </div>
    </section>

    <!-- Introduction Section -->
    <section class="introduction-section" id="intro">
        <div class="intro-container">
            <div class="intro-text">
                <h2>Introduction</h2>
                <p>
                    Ashen Light is an adventure strategy RPG that blends exploration, tactical combat, and character progression in a dynamic fantasy setting. 
                    Players traverse a vast world shaped by conflict and mystery, making strategic decisions that influence both battles and the unfolding narrative.
                </p>
            </div>
            <div class="intro-image">
                <img src="@Model.ResolveImageUrl("images/deviljho.jpg")" alt="Game Screenshot" />
            </div>
        </div>
    </section>

    <!-- Explore Section -->
    <section class="explore-section">
        <h2>Explore the vast world</h2>
        <p class="explore-subtitle">
            Challenge an ever-growing roster of monsters, collect their materials,
            and forge powerful weapons and armor.
        </p>

        <div class="explore-content">
            <div class="world-map">
                <img src="@Model.ResolveImageUrl("images/FullMap.png")" alt="World of Monster Hunter" />
            </div>

            <div class="feature-cards">
                <div class="feature-card">
                    <img src="@Model.ResolveImageUrl("images/eldenringmaiden.png")" alt="Companion" />
                    <p>Glean to your companions</p>
                </div>
                <div class="feature-card">
                    <img src="@Model.ResolveImageUrl("images/rathalos.jpg")" alt="Monster" />
                    <p>And hunt dangerous monsters</p>
                </div>
            </div>
        </div>
    </section>

    <!-- About the Game Section -->
    <section class="about-game-section">
        <h2>About the game</h2>

        <div class="game-categories">
            <div class="category-group">
                <h3>Database</h3>
                <div class="category-links">
                    <a href="/Items" class="category-link">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M20 6h-2.18c.11-.31.18-.65.18-1 0-1.66-1.34-3-3-3-1.05 0-1.96.54-2.5 1.35l-.5.67-.5-.68C10.96 2.54 10.05 2 9 2 7.34 2 6 3.34 6 5c0 .35.07.69.18 1H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2z" />
                        </svg>
                        <span>Items</span>
                    </a>
                    <a href="/Items" class="category-link">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2L4 5v6.09c0 5.05 3.41 9.76 8 10.91 4.59-1.15 8-5.86 8-10.91V5l-8-3z" />
                        </svg>
                        <span>Armors</span>
                    </a>
                    <a href="/Items" class="category-link">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M6.92 5H5l9 9 1-.94m4.96 6.06l-.84.84a.996.996 0 01-1.41 0l-3.12-3.12-2.68 2.66-1.41-1.41 6.59-6.59-1.37-1.37-6.36 6.36L3 13.72V20h6.28l-2.39-2.39 2.66-2.68-3.12-3.12c-.39-.39-.39-1.02 0-1.41l.84-.84c.39-.39 1.02-.39 1.41 0l7.82 7.82c.39.39.39 1.02 0 1.41M20 4v-.5C20 2.68 19.32 2 18.5 2S17 2.68 17 3.5V4c-.55 0-1 .45-1 1v1c0 .55.45 1 1 1v1l2-2v2c.55 0 1-.45 1-1V5c0-.55-.45-1-1-1z" />
                        </svg>
                        <span>Weapons</span>
                    </a>
                    <a href="/News/ReadNews/317a358d-8091-44c7-8445-5f4a673e267e" class="category-link">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M11 17h2v-6h-2v6zm1-15C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zM11 9h2V7h-2v2z" />
                        </svg>
                        <span>Tutorials</span>
                    </a>
                </div>
            </div>

            <div class="category-group">
                <h3>Gameplay</h3>
                <div class="category-links">
                    <a href="/companions" class="category-link">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" />
                        </svg>
                        <span>Companions</span>
                    </a>
                    <a href="/npcs?monster=true" class="category-link">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                        </svg>
                        <span>Monsters</span>
                    </a>
                </div>
            </div>

            <div class="category-group">
                <h3>World</h3>
                <div class="category-links">
                    <a href="/npcs" class="category-link">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                        </svg>
                        <span>NPCs</span>
                    </a>
                </div>
            </div>
        </div>
    </section>
</div>