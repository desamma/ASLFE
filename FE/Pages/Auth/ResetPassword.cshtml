@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="signin-container">
    <div class="signin-background">
        <div class="signin-card">
            <h1 class="signin-title">Reset Password</h1>

            <div class="form-description">
                <p>Enter your new password below.</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="validation-message">@Model.ErrorMessage</div>
            }

            @if (Model.IsTokenValid)
            {
                <form method="post" class="signin-form">
                    <input type="hidden" asp-for="Input.UserId" />
                    <input type="hidden" asp-for="Input.Token" />

                    <div asp-validation-summary="All" class="text-danger"></div>

                    <input asp-for="Input.NewPassword" type="password" class="form-input" placeholder="New Password" />
                    <span asp-validation-for="Input.NewPassword" class="validation-error"></span>

                    <input asp-for="Input.ConfirmPassword" type="password" class="form-input" placeholder="Confirm Password" />
                    <span asp-validation-for="Input.ConfirmPassword" class="validation-error"></span>

                    <button type="submit" class="btn-login">
                        Reset Password
                    </button>
                </form>

                <div class="signin-footer">
                    <a href="/Auth/Login" class="signin-link">Back to Login</a>
                </div>
            }
            else
            {
                <div class="reset-status">
                    <p>The password reset link is invalid or has expired.</p>
                    <a href="/Auth/ForgotPassword" class="btn btn-primary" style="display: inline-block; margin-top: 20px;">Request a new reset link</a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
