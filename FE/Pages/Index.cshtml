@page
@model IndexModel
@{
    ViewData["Title"] = "Homepage";
}

<div class="game-intro-container">
    <!-- Hero Section -->
    <section class="hero-section">
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="hero-bottom-left">
                <h1 class="hero-title">The Hunt Starts Now</h1>
                <p class="hero-subtitle">
                    The world of <strong>Monster Hunter</strong> has become connected with our world<br />
                    — Head outdoors, explore, and fend off mighty monsters.
                </p>
                <a href="#intro" class="learn-more">Learn How To Play</a>
            </div>

            <div class="hero-bottom-right">
                <a href="#" class="cta-button">Download Now</a>
            </div>
        </div>
        <div class="hero-image">
            <img src="@Model.ResolveImageUrl("images/startscreemas.png")" alt="Monster Hunter Mask" />
        </div>
    </section>

    <!-- Introduction Section -->
    <section class="introduction-section" id="intro">
        <div class="intro-container">
            <div class="intro-text">
                <h2>Introduction</h2>
                <p>
                    Ashen light is an in an open-world adventure strategy role-playing game
                    developed by Chinese game development studio Han-Squirrel Studio and published
                    by Han-Squirrel Studio, X.D. Network Inc. It was published under early access
                    on Microsoft Windows and Nintendo Switch, before having its 1.0 release available
                    on December 15, 2021.
                </p>
            </div>
            <div class="intro-image">
                <img src="@Model.ResolveImageUrl("images/deviljho.jpg")" alt="Game Screenshot" />
            </div>
        </div>
    </section>

    <!-- Explore Section -->
    <section class="explore-section">
        <h2>Explore the vast open-world</h2>
        <p class="explore-subtitle">
            Challenge an ever-growing roster of monsters, collect their materials,
            and forge powerful weapons and armor.
        </p>

        <div class="explore-content">
            <div class="world-map">
                <img src="@Model.ResolveImageUrl("images/FullMap.png")" alt="World of Monster Hunter" />
            </div>

            <div class="feature-cards">
                <div class="feature-card">
                    <img src="@Model.ResolveImageUrl("images/eldenringmaiden.png")" alt="Companion" />
                    <p>Glean to your companions</p>
                </div>
                <div class="feature-card">
                    <img src="@Model.ResolveImageUrl("images/rathalos.jpg")" alt="Monster" />
                    <p>And hunt dangerous monsters</p>
                </div>
            </div>
        </div>
    </section>

    <!-- About the Game Section -->
    <section class="about-game-section">
        <h2>About the game</h2>

        <div class="game-categories">
            <div class="category-group">
