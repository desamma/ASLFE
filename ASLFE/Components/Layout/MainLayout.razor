@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inherits LayoutComponentBase

<header class="game-header">
    <div class="header-container">
        <a href="/" class="logo">
            <svg viewBox="0 0 24 24" fill="currentColor" class="logo-icon">
                <circle cx="8" cy="8" r="3" />
                <circle cx="8" cy="16" r="3" />
                <circle cx="16" cy="8" r="3" />
                <circle cx="16" cy="16" r="3" />
            </svg>
        </a>

        <nav class="main-nav">
            <div class="nav-item dropdown">
                <button class="nav-button">
                    Gameplay
                    <svg viewBox="0 0 24 24" fill="currentColor" class="dropdown-icon">
                        <path d="M7 10l5 5 5-5z" />
                    </svg>
                </button>
            </div>

            <a href="/news" class="nav-item">News</a>

            <div class="nav-item dropdown">
                <button class="nav-button">
                    Shop
                    <svg viewBox="0 0 24 24" fill="currentColor" class="dropdown-icon">
                        <path d="M7 10l5 5 5-5z" />
                    </svg>
                </button>
            </div>
        </nav>

        <AuthorizeView>
            <Authorized>
                <div class="user-profile-group" style="display: flex; align-items: center; gap: 12px;">

                    @* Display Avatar if it exists, otherwise a default icon *@
                    @{
                        var avatarUrl = context.User.FindFirst("Avatar")?.Value;
                        var username = context.User.Identity?.Name;
                    }

                    <div class="user-info">
                        @if (!string.IsNullOrEmpty(avatarUrl))
                        {
                            <img src="@avatarUrl" alt="Avatar" class="user-avatar" style="width: 32px; height: 32px; border-radius: 50%;" />
                        }
                        else
                        {
                            <div class="avatar-placeholder" style="width: 32px; height: 32px; background: #444; border-radius: 50%; display: inline-block;"></div>
                        }
                        <span class="username" style="color: white; font-weight: 500; margin-left: 8px;">@username</span>
                    </div>

                    <form action="/local-logout" method="post" style="display:inline;">
                        <AntiforgeryToken />
                        <button type="submit" class="btn-logout">Logout</button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <a href="/signin" class="btn-signin">Sign in</a>
                <a href="/register" class="btn-register">Register</a>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</header>
@* 
    <div class="sidebar">
        <NavMenu />
    </div>
 *@

<main>
    @Body
</main>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>