@page
@model FE.Pages.Gacha.IndexModel
@{
    ViewData["Title"] = "Prayer Hall";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Cinzel:wght@400;600;700&family=Raleway:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
    /* Reset cơ bản chỉ trong phạm vi Gacha để không hỏng layout toàn trang */
    .ashen-gacha-wrapper *, .ashen-gacha-wrapper *::before, .ashen-gacha-wrapper *::after {
        box-sizing: border-box;
    }

    :root {
        --gold: #f5c84a;
        --ember: #ff6820;
        --purple: #b46aff;
        --blue: #5cb8ff;
        --bg-deep: #04020c;
        --text: #f0e8d8;
        --text-dim: rgba(220,200,160,0.55);
        --panel: rgba(10,6,26,0.92);
        --border: rgba(245,200,74,0.18);
    }

    /* Vùng chứa chính - Căn giữa màn hình */
    .ashen-gacha-wrapper {
        background-color: var(--bg-deep);
        color: var(--text);
        min-height: calc(100vh - 64px);
        display: flex;
        align-items: center; /* Căn giữa theo chiều dọc */
        justify-content: center; /* Căn giữa theo chiều ngang */
        position: relative;
        overflow: hidden;
        font-family: 'Raleway', sans-serif;
    }

    /* Hiệu ứng Canvas nền sao */
    #starfield {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        width: 100%;
        height: 100%;
    }

    /* ══════════════════════════════
           CARD NẰM NGANG (MỚI)
        ══════════════════════════════ */
    .gacha-horizontal-card {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: row; /* Dàn theo chiều ngang */
        width: 900px; /* Kích thước vừa phải */
        max-width: 95vw;
        height: 480px; /* Chiều cao cố định cho đẹp */
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 16px;
        box-shadow: 0 15px 50px rgba(0,0,0,0.8), inset 0 0 0 1px rgba(255,255,255,0.05);
        overflow: hidden;
    }

    /* ══════════════════════════════
           TRÁI: BANNER SECTION
        ══════════════════════════════ */
    #banner-display {
        flex: 1.3; /* Chiếm nhiều không gian hơn phần nút bấm một chút */
        position: relative;
        background-color: #1a0810;
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: flex-end;
        padding: 40px;
        border-right: 1px solid var(--border); /* Đường kẻ chia đôi */
    }

    /* Lớp phủ Glow cho Banner từ database */
    .hero-glow-1 {
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 70% 70% at 50% 35%, rgba(255,90,10,0.15) 0%, transparent 70%);
        pointer-events: none;
    }

    .hero-glow-2 {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 60%;
        background: linear-gradient(transparent, rgba(4,2,12,0.98) 95%);
        pointer-events: none;
    }

    .hero-info {
        position: relative;
        z-index: 3;
        width: 100%;
    }

    .banner-type-tag {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: linear-gradient(90deg, rgba(255,104,32,0.25), rgba(245,200,74,0.15));
        border: 1px solid rgba(255,140,30,0.35);
        border-radius: 3px;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--gold);
        padding: 5px 12px;
        margin-bottom: 12px;
    }

        .banner-type-tag::before {
            content: '';
            width: 6px;
            height: 6px;
            background: var(--ember);
            border-radius: 50%;
            box-shadow: 0 0 8px var(--ember);
            animation: blinkDot 1.5s ease-in-out infinite;
        }
    @@keyframes blinkDot {
        0%,100%

    {
        opacity: 1;
    }

    50% {
        opacity: 0.3;
    }

    }

    #banner-title {
        font-family: 'Cinzel Decorative', serif;
        font-size: 32px;
        font-weight: 900;
        color: #fff8ea;
        text-shadow: 0 0 20px rgba(255,160,40,0.8), 0 2px 4px rgba(0,0,0,1);
        letter-spacing: 1.5px;
        line-height: 1.2;
        margin: 0 0 8px 0;
        text-transform: uppercase;
    }

    #banner-desc {
        font-size: 14px;
        color: var(--text-dim);
        letter-spacing: 0.5px;
        margin: 0;
        line-height: 1.5;
    }

    /* ══════════════════════════════
           PHẢI: CONTROLS (PITY & WISH)
        ══════════════════════════════ */
    .controls {
        flex: 1;
        background: transparent;
        padding: 40px 30px;
        display: flex;
        flex-direction: column; /* Xếp dọc các block bên trong */
        justify-content: center; /* Căn giữa theo chiều dọc */
        gap: 40px; /* Khoảng cách giữa phần Pity và Nút bấm */
    }

    .pity-col {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .pity-header {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .pity-heading {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--text-dim);
    }

    .pity-count {
        font-family: 'Cinzel', serif;
        font-size: 13px;
        color: var(--gold);
        font-weight: bold;
    }

    #pity-counter {
        font-size: 20px;
        color: #fff;
        text-shadow: 0 0 8px var(--gold);
    }

    .pity-foot {
        display: flex;
        flex-direction: column;
        gap: 10px;
        align-items: flex-start;
    }

    #btn-history {
        background: none;
        border: none;
        cursor: pointer;
        font-size: 12px;
        letter-spacing: 1px;
        color: rgba(200,170,100,0.6);
        text-decoration: underline;
        text-underline-offset: 3px;
        font-family: 'Raleway', sans-serif;
        transition: color 0.2s;
        padding: 0;
    }

        #btn-history:hover {
            color: var(--gold);
        }

    .wish-btns {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .btn-wish {
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
        border: none;
        cursor: pointer;
        border-radius: 8px;
        font-family: 'Raleway', sans-serif;
        transition: transform 0.15s, filter 0.15s, box-shadow 0.2s;
        width: 100%;
        gap: 14px;
    }

        .btn-wish:hover:not(:disabled) {
            transform: translateY(-2px);
            filter: brightness(1.15);
        }

        .btn-wish:active:not(:disabled) {
            transform: scale(0.97);
        }

        .btn-wish:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            filter: grayscale(1);
        }

        .btn-wish::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(110deg, transparent 40%, rgba(255,255,255,0.15) 50%, transparent 60%);
            transform: translateX(-100%);
            transition: transform 0s;
        }

        .btn-wish:hover:not(:disabled)::after {
            transform: translateX(100%);
            transition: transform 0.45s ease;
        }

    .btn-single {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.13);
    }

    .btn-multi {
        background: linear-gradient(130deg, #8c3500 0%, #c96100 45%, #f09b10 100%);
        box-shadow: 0 5px 22px rgba(220,130,20,0.45), inset 0 1px 0 rgba(255,230,150,0.25);
    }

    .wish-type {
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 3px;
        text-transform: uppercase;
        display: block;
        margin-bottom: 6px;
        text-align: left;
    }

    .btn-single .wish-type {
        color: rgba(180,165,130,0.7);
    }

    .btn-multi .wish-type {
        color: rgba(255,240,200,0.85);
        text-shadow: 0 1px 2px rgba(0,0,0,0.5);
    }

    .wish-cost {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: 'Cinzel', serif;
        font-size: 18px;
        font-weight: 700;
    }

    .btn-single .wish-cost {
        color: #c8a868;
    }

    .btn-multi .wish-cost {
        color: #fff;
        text-shadow: 0 1px 3px rgba(0,0,0,0.6);
    }

    /* ══════════════════════════════
           MODALS & OVERLAYS
        ══════════════════════════════ */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 200;
        background: rgba(0,0,0,0.92);
        backdrop-filter: blur(5px);
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .summon-portal {
        position: relative;
        width: 180px;
        height: 180px;
        margin-bottom: 20px;
    }

    .portal-ring {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        border: 2px solid rgba(255,100,20,0.5);
        animation: portalSpin linear infinite;
    }

        .portal-ring:nth-child(1) {
            animation-duration: 3s;
            border-color: rgba(255,130,30,0.6);
        }

        .portal-ring:nth-child(2) {
            inset: 12px;
            animation-duration: 2s;
            animation-direction: reverse;
            border-color: rgba(245,200,74,0.5);
        }

        .portal-ring:nth-child(3) {
            inset: 26px;
            animation-duration: 4s;
            border-color: rgba(180,106,255,0.4);
        }
    @@keyframes portalSpin {
        from

    {
        transform: rotate(0)
    }

    to {
        transform: rotate(360deg)
    }

    }

    .portal-core {
        position: absolute;
        top: 40px;
        left: 40px;
        right: 40px;
        bottom: 40px;
        border-radius: 50%;
        background: radial-gradient(circle, #ff8c30, #c94000 50%, #400c00);
        animation: coreBreath 0.8s ease-in-out infinite alternate;
        box-shadow: 0 0 60px rgba(255,100,20,0.8);
    }
    @@keyframes coreBreath {
        from

    {
        transform: scale(0.92);
    }

    to {
        transform: scale(1.08);
    }

    }

    .parchment-container {
        background: linear-gradient(170deg, #160c2c 0%, #0c0818 100%);
        border: 1px solid rgba(255,160,40,0.28);
        border-radius: 14px;
        padding: 30px;
        width: 90%;
        max-width: 600px;
        box-shadow: 0 0 80px rgba(200,100,20,0.2), inset 0 0 0 1px rgba(255,255,255,0.04);
        animation: modalIn 0.35s cubic-bezier(.2,.8,.3,1.1) both;
    }
    @@keyframes modalIn {
        from

    {
        opacity: 0;
        transform: scale(0.88) translateY(16px);
    }

    to {
        opacity: 1;
        transform: scale(1) translateY(0);
    }

    }

    .parchment-container h2 {
        font-family: 'Cinzel Decorative', serif;
        font-size: 20px;
        color: #f8e8c4;
        text-align: center;
        margin: 0 0 20px 0;
        letter-spacing: 2px;
        text-shadow: 0 0 20px rgba(255,170,40,0.4);
        border: none;
    }

    .item-grid {
        display: grid;
        gap: 10px;
        margin-bottom: 25px;
        grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
        max-width: 100%;
    }

    .gacha-item-card {
        border-radius: 9px;
        padding: 12px 5px 8px;
        text-align: center;
        cursor: default;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        animation: cardPop 0.45s cubic-bezier(.2,.8,.3,1.2) backwards;
        transition: transform 0.2s;
        display: flex;
        flex-direction: column;
        align-items: center;
        box-shadow: none;
        min-height: 110px;
        justify-content: center;
    }

        .gacha-item-card:hover {
            transform: translateY(-4px) scale(1.05);
        }

        .gacha-item-card:hover {
            transform: translateY(-4px) scale(1.05);
        }
    @@keyframes cardPop {
        from

    {
        opacity: 0;
        transform: scale(0.5) rotate(-8deg);
    }

    to {
        opacity: 1;
        transform: scale(1) rotate(0);
    }

    }

    .gacha-item-card img {
        max-width: 50px;
        max-height: 50px;
        object-fit: contain;
        margin-bottom: 8px;
        filter: drop-shadow(0 4px 6px rgba(0,0,0,0.5));
    }

    .gacha-item-card span {
        color: #cfc0a0;
        font-size: 11px;
        line-height: 1.3;
        margin-bottom: 4px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        height: 28px;
        font-weight: normal;
    }

    .gacha-item-card small {
        font-size: 10px;
        letter-spacing: 1px;
    }

    .rarity-5 {
        background: rgba(255,160,30,0.12);
        border-color: rgba(255,160,30,0.45);
        box-shadow: 0 0 20px rgba(255,130,20,0.3) !important;
    }

        .rarity-5 small {
            color: #f5c040;
            text-shadow: 0 0 5px rgba(245,192,64,0.5);
        }

    .rarity-4 {
        background: rgba(160,60,220,0.10);
        border-color: rgba(160,60,220,0.4);
        box-shadow: 0 0 15px rgba(160,60,220,0.2) !important;
    }

        .rarity-4 small {
            color: #b060e0;
        }

    .rarity-3 {
        background: rgba(80,160,240,0.05);
        border-color: rgba(70,130,220,0.28);
        box-shadow: none !important;
    }

        .rarity-3 small {
            color: #5090c0;
        }

    .btn-close-modal {
        width: 100%;
        padding: 14px;
        background: linear-gradient(90deg, rgba(255,130,20,0.15), rgba(245,200,74,0.15));
        border: 1px solid rgba(245,200,74,0.3);
        color: var(--gold);
        border-radius: 8px;
        font-family: 'Cinzel', serif;
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 2px;
        cursor: pointer;
        transition: background 0.2s, box-shadow 0.2s;
    }

        .btn-close-modal:hover {
            background: linear-gradient(90deg, rgba(255,130,20,0.28), rgba(245,200,74,0.28));
            box-shadow: 0 0 20px rgba(245,200,74,0.15);
        }

    .history-container {
        background: #0c0918;
        border: 1px solid rgba(255,160,40,0.22);
        border-radius: 14px;
        width: 90%;
        max-width: 650px;
        max-height: 80vh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        animation: modalIn 0.3s ease both;
        box-shadow: 0 20px 50px rgba(0,0,0,0.8);
        padding: 0;
    }

        .history-container > div:first-child {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 20px 25px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
            margin: 0;
        }

        .history-container h2 {
            font-family: 'Cinzel', serif;
            font-size: 18px;
            color: #f0e0c0;
            letter-spacing: 1.5px;
            border: none;
            padding: 0;
        }

        .history-container button[onclick="closeHistory()"] {
            color: rgba(200,170,120,0.45) !important;
            font-size: 28px;
            line-height: 1;
            transition: color 0.2s;
            padding: 0;
            background: none;
            border: none;
            cursor: pointer;
        }

            .history-container button[onclick="closeHistory()"]:hover {
                color: var(--gold) !important;
            }

    .history-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Raleway', sans-serif;
    }

        .history-table th {
            position: sticky;
            top: 0;
            z-index: 1;
            padding: 12px 20px;
            font-size: 10px;
            font-weight: 800;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: rgba(200,170,100,0.45);
            text-align: left;
            background: rgba(12,9,24,0.98);
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }

        .history-table td {
            padding: 14px 20px;
            font-size: 13px;
            border-bottom: 1px solid rgba(255,255,255,0.04);
            color: rgba(210,195,165,0.8);
        }

        .history-table tr:hover td {
            background: rgba(255,255,255,0.025);
        }
</style>

<div class="ashen-gacha-wrapper">
    <canvas id="starfield"></canvas>

    <div class="status-strip" style="display: none;">
        <div class="gem-chip">
            <span class="gem-amount" id="vp-balance-display">0</span>
        </div>
    </div>

    <div class="gacha-horizontal-card">

         <div id="banner-display">
        <video id="banner-video" autoplay muted loop playsinline style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 1;">
            <source id="banner-video-source" src="" type="video/mp4">
            Your browser does not support the video tag.
        </video>
        
        <div class="hero-glow-1"></div>
        <div class="hero-glow-2"></div>

        <div class="hero-info">
            <div class="banner-type-tag">Limited Event Wish</div>
            <h1 id="banner-title">Loading...</h1>
            <p id="banner-desc">Connecting to server...</p>
        </div>
    </div>

        <div class="controls">
            <div class="pity-col">
                <div class="pity-header">
                    <span class="pity-heading">Guarantee Progress</span>
                    <span class="pity-count"><span id="pity-counter">--</span> pulls until 5★</span>
                </div>

                <div class="pity-foot">
                    <span style="font-size: 11px; color: rgba(180,106,255,0.8); letter-spacing: 1px; display: flex; align-items: center; gap: 3px; font-weight: 600;">✦ 50/50 active</span>
                    <button id="btn-history">View Wish History</button>
                </div>
            </div>

            <div class="wish-btns">
                <button class="btn-wish btn-single" id="wish-single">
                    <div style="text-align: left;">
                        <span class="wish-type">Wish ×1</span>
                        <span class="wish-cost">
                            <img src="/images/virtual-currency.png" alt="VP" style="width: 18px; height: 18px; object-fit: contain;">
                            <span id="cost-single">...</span>
                        </span>
                    </div>
                    <span style="font-size: 22px; opacity: 0.5;">›</span>
                </button>

                <button class="btn-wish btn-multi" id="wish-multi">
                    <div style="text-align: left;">
                        <span class="wish-type">Wish ×10</span>
                        <span class="wish-cost">
                            <img src="/images/virtual-currency.png" alt="VP" style="width: 18px; height: 18px; object-fit: contain;">
                            <span id="cost-multi">...</span>
                        </span>
                    </div>
                    <span style="font-size: 22px; opacity: 0.5;">›</span>
                </button>
            </div>
        </div>

    </div>

    <div id="chest-animation-overlay" class="modal-overlay" style="display:none; flex-direction: column;">
        <div class="summon-portal">
            <div class="portal-ring"></div>
            <div class="portal-ring"></div>
            <div class="portal-ring"></div>
            <div class="portal-core"></div>
        </div>
        <h3 style="font-family: 'Cinzel Decorative', serif; font-size: 18px; color: #f5c84a; letter-spacing: 4px; animation: fadeGlow 1.2s ease-in-out infinite alternate;">SUMMONING...</h3>
    </div>

    <div id="gacha-result-modal" class="modal-overlay" style="display:none;">
        <div class="parchment-container">
            <h2>REWARDS OBTAINED</h2>
            <div id="result-grid" class="item-grid">
            </div>
            <button class="btn-close-modal" onclick="closeModal()">CONTINUE</button>
        </div>
    </div>

    <div id="history-modal" class="modal-overlay" style="display:none;">
        <div class="history-container">
            <div>
                <h2>Wish History</h2>
                <button onclick="closeHistory()">&times;</button>
            </div>
            <div style="flex: 1; overflow-y: auto;">
                <table class="history-table">
                    <thead>
                        <tr>
                            <th>Item Name</th>
                            <th>Type</th>
                            <th>Rarity</th>
                            <th>Time</th>
                        </tr>
                    </thead>
                    <tbody id="history-tbody">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const c = document.getElementById('starfield');
        if(!c) return;
        const ctx = c.getContext('2d');
        let stars = [];
        function resize() {
            c.width = c.parentElement.clientWidth;
            c.height = c.parentElement.clientHeight;
        }
        function initStars() {
            stars = Array.from({ length: 120 }, () => ({
                x: Math.random() * c.width, y: Math.random() * c.height,
                r: Math.random() * 1.2 + 0.2, a: Math.random(),
                da: (Math.random() * 0.005 + 0.002) * (Math.random() < 0.5 ? 1 : -1)
            }));
        }
        function draw() {
            ctx.clearRect(0, 0, c.width, c.height);
            stars.forEach(s => {
                s.a = Math.max(0, Math.min(1, s.a + s.da));
                if (s.a <= 0 || s.a >= 1) s.da *= -1;
                ctx.beginPath(); ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(220,210,190,${s.a * 0.6})`; ctx.fill();
            });
            requestAnimationFrame(draw);
        }
        window.addEventListener('resize', () => { resize(); initStars(); });
        resize(); initStars(); draw();
    });
</script>

@section Scripts {
    <script src="~/js/gacha.js" asp-append-version="true"></script>
}