@page
@model FE.Pages.Admin.AdminUsersModel
@{
    ViewData["Title"] = "User Management";
}

<div class="container-fluid admin-wrapper mt-4 mb-5">
    <h2 class="admin-title">User Management</h2>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="validation-message alert alert-danger" style="margin-bottom: 20px;">@Model.ErrorMessage</div>
    }

    <form method="get" class="mb-4">
        <div class="search-container">
            <span style="padding-left: 12px; color: #6b7280;">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0" />
                </svg>
            </span>
            <input type="text" asp-for="SearchName" class="search-input" placeholder="Search by username or email..." autocomplete="off"
                   style="flex: 1; background: transparent !important; background-color: transparent !important; border: none !important; outline: none !important; box-shadow: none !important; color: white !important; padding: 8px 12px;" />
            <button type="submit" class="btn-search">Search</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="admin-table">
            <thead>
                <tr>
                    <th style="width: 15%;">Username</th>
                    <th style="width: 25%;">Email</th>
                    <th style="width: 15%;">Currency (VP)</th>
                    <th style="width: 10%;">Pity</th>
                    <th style="width: 10%;">Status</th>
                    <th style="width: 25%;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td style="color: #fff; font-weight: 600;">@user.UserName</td>
                        <td style="color: #9ca3af;">@user.Email</td>
                        <td style="color: #34d399; font-weight: 700; font-size: 1.05rem;">@user.CurrencyAmount VP</td>
                        <td>@user.PityCounter</td>
                        <td>
                            @if (user.IsBanned)
                            {
                                <span class="status-badge status-banned">BANNED</span>
                            }
                            else
                            {

                                <span class="status-badge status-active">ACTIVE</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex align-items-center justify-content-center gap-2" style="flex-wrap: nowrap; min-width: 250px;">
                                <form method="post" asp-page-handler="ToggleBan" class="m-0">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="action-btn @(user.IsBanned ? "btn-unban" : "btn-ban")" style="width: 80px;">
                                        @(user.IsBanned ? "Unban" : "Ban")
                                    </button>
                                </form>
                                <form method="post" asp-page-handler="AdjustCurrency" class="m-0 d-flex align-items-center gap-2">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <input type="number" name="amountChange" class="currency-input" placeholder="+/- VP" required />
                                    <button type="submit" class="action-btn btn-save">Save</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>