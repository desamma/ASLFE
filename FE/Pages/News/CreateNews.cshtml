@page
@model CreateNewsModel
@{
    ViewData["Title"] = Model.IsEditing ? "Edit Game News" : "Create Game News";
}

<div class="news-create-container">
    <div class="news-create-card">
        <h1 class="news-title">@(Model.IsEditing ? "Edit Game News" : "Create Game News")</h1>

        <form method="post" enctype="multipart/form-data" class="news-form">
            <div asp-validation-summary="All" class="text-danger"></div>

            <!-- Title Input -->
            <div class="form-group">
                <label for="Title" class="form-label">Title</label>
                <input asp-for="Input.Title" type="text" class="form-control" placeholder="Enter news title" maxlength="500" />
                <span asp-validation-for="Input.Title" class="text-danger"></span>
            </div>

            <!-- Banner Path Input -->
            <div class="form-group">
                <label for="BannerPath" class="form-label">Banner Image (Optional)</label>
                <input asp-for="Input.BannerPath" type="text" class="form-control" placeholder="e.g., Firebase image URL" />
                <span asp-validation-for="Input.BannerPath" class="text-danger"></span>
                <small class="form-text">Paste Firebase Cloud Storage image URL</small>
            </div>

            <!-- Description Input -->
            <div class="form-group">
                <label for="Description" class="form-label">Description</label>
                <textarea asp-for="Input.Description" class="form-control" placeholder="Enter news description" maxlength="500" rows="3"></textarea>
                <span asp-validation-for="Input.Description" class="text-danger"></span>
                <small class="form-text"><span id="descriptionCount">0</span>/500</small>
            </div>

            <!-- Rich Text Editor -->
            <div class="form-group">
                <label for="Content" class="form-label">Content</label>
                <div class="editor-toolbar">
                    <button type="button" class="editor-btn" onclick="addSeparator()" title="Add Separator">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                            <line x1="0" y1="12" x2="24" y2="12" stroke="currentColor" stroke-width="2"/>
                        </svg>
                        <span>Separator</span>
                    </button>
                    <button type="button" class="editor-btn" onclick="showImageDialog()" title="Add Image URL">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                            <rect x="2" y="2" width="20" height="20" rx="2" fill="none" stroke="currentColor" stroke-width="2"/>
                            <circle cx="8" cy="8" r="2" fill="currentColor"/>
                            <path d="M2 16l6-6 8 8 8-8" stroke="currentColor" stroke-width="2" fill="none"/>
                        </svg>
                        <span>Image URL</span>
                    </button>
                    <button type="button" class="editor-btn" onclick="showImageBrowser()" title="Browse Cloud Images">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                            <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                        </svg>
                        <span>Browse Cloud</span>
                    </button>
                    <button type="button" class="editor-btn" onclick="showUploadDialog()" title="Upload Image">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                            <path d="M19.35 10.04C18.67 6.59 15.64 4 12 4c-1.48 0-2.85.43-4.01 1.17l1.46 1.46C10.21 5.23 11.08 5 12 5c3.04 0 5.5 2.46 5.5 5.5v.5H19c1.66 0 3 1.34 3 3 0 1.13-.64 2.11-1.56 2.62l1.45 1.45c.9-.86 1.48-2.06 1.48-3.39 0-1.5-.583-2.85-1.54-3.89zM16.5 16.5H13v3h-2v-3H8.5l4-4 4 4z"/>
                        </svg>
                        <span>Upload Image</span>
                    </button>
                </div>
                <textarea asp-for="Input.Content" id="ContentEditor" class="editor-textarea" placeholder="Your content will appear here..."></textarea>
                <span asp-validation-for="Input.Content" class="text-danger"></span>
                <small class="form-text"><span id="contentCount">0</span>/10000</small>
            </div>

            <!-- Preview Section -->
            <div class="form-group">
                <label class="form-label">Preview</label>
                <div id="contentPreview" class="preview-box"></div>
            </div>

            <!-- Submit Button -->
            <button type="submit" class="btn-submit">@(Model.IsEditing ? "Update News" : "Create News")</button>
            @if (Model.IsEditing && Model.EditingNewsId.HasValue)
            {
                <a href="/News/ReadNews/@Model.EditingNewsId" class="btn-cancel">Cancel</a>
            }
        </form>
    </div>
</div>

<!-- Image URL Dialog -->
<div id="imageDialog" class="modal-overlay" style="display: none;" onclick="closeImageDialog(event)">
    <div class="modal-content" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h2>Add Image URL</h2>
            <button type="button" class="modal-close" onclick="closeImageDialog()">&times;</button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label for="imageName" class="form-label">Image URL</label>
                <input type="text" id="imageName" class="form-control" placeholder="Paste Firebase Cloud Storage image URL" />
                <small class="form-text">Use URLs from Firebase Cloud Storage or browse below</small>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cancel" onclick="closeImageDialog()">Cancel</button>
            <button type="button" class="btn-primary" onclick="insertImage()">Insert Image</button>
        </div>
    </div>
</div>

<!-- Image Browser Dialog -->
<div id="imageBrowserDialog" class="modal-overlay" style="display: none;" onclick="closeImageBrowser(event)">
    <div class="modal-content modal-content-large" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h2>Select Cloud Image</h2>
            <button type="button" class="modal-close" onclick="closeImageBrowser()">&times;</button>
        </div>
        <div class="modal-body">
            <div id="imageBrowserContent" class="image-browser-grid">
                <div class="loading-spinner">Loading images...</div>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cancel" onclick="closeImageBrowser()">Close</button>
        </div>
    </div>
</div>

<!-- Image Upload Dialog -->
<div id="uploadDialog" class="modal-overlay" style="display: none;" onclick="closeUploadDialog(event)">
    <div class="modal-content" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h2>Upload Image</h2>
            <button type="button" class="modal-close" onclick="closeUploadDialog()">&times;</button>
        </div>
        <div class="modal-body">
            <div id="uploadPreview" class="upload-preview" style="display: none;">
                <img id="uploadImage" alt="Preview" style="max-width: 100%; max-height: 300px; border-radius: 6px;" />
            </div>
            <div class="form-group">
                <label for="uploadFile" class="form-label">Select Image File</label>
                <input type="file" id="uploadFile" class="form-control" accept="image/*" />
                <small class="form-text">Max 5MB. Supported: JPG, PNG, GIF, WebP, BMP</small>
            </div>
            <div id="uploadStatus" class="upload-status" style="display: none;"></div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cancel" onclick="closeUploadDialog()">Cancel</button>
            <button type="button" class="btn-primary" id="uploadBtn" onclick="performImageUpload()">Upload & Insert</button>
        </div>
    </div>
</div>

<!-- Notification Modal -->
<div id="notificationModal" class="modal-overlay" style="display: none;" onclick="closeNotificationModal(event)">
    <div class="modal-content modal-notification" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h2 id="notificationTitle">Notification</h2>
            <button type="button" class="modal-close" onclick="closeNotificationModal()">&times;</button>
        </div>
        <div class="modal-body">
            <div id="notificationContent" class="notification-content"></div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-primary" id="notificationBtn" onclick="handleNotificationAction()">OK</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.createNewsPageUrls = {
            getImages: '@Url.Page("/News/CreateNews", "GetImages")',
            uploadImage: '@Url.Page("/News/CreateNews", "UploadImage")'
        };
        window.createNewsPageState = {
            errorMessage: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ErrorMessage ?? string.Empty)),
            successMessage: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SuccessMessage ?? string.Empty)),
            successRedirectUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.IsEditing && Model.EditingNewsId.HasValue ? Url.Page("/News/ReadNews", new { id = Model.EditingNewsId }) : string.Empty))
        };
    </script>
    <script src="~/js/news-editor.js"></script>
}
