@page
@model FE.Pages.Admin.AdminPaymentModel
@{
    ViewData["Title"] = "Transactions Dashboard";
}

<style>
    .my-super-search {
        display: flex !important; align-items: center !important;
        background-color: #25252d !important; border: 1px solid #3f3f46 !important;
        border-radius: 8px !important; padding: 6px !important; 
        width: 100% !important; max-width: 600px !important; box-sizing: border-box !important;
    }
    .my-super-search:focus-within { border-color: #6366f1 !important; box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2) !important; }
    .my-icon { color: #8b8d98 !important; margin: 0 12px 0 8px !important; flex-shrink: 0 !important; }
    .my-input {
        flex: 1 !important; background: transparent !important; border: none !important;
        color: #f4f4f5 !important; outline: none !important; box-shadow: none !important;
        padding: 0 !important; font-size: 0.95rem !important; min-width: 0 !important; height: 36px !important;
    }
    .my-input::placeholder { color: #71717a !important; }
    .my-input:-webkit-autofill, .my-input:-webkit-autofill:hover, .my-input:-webkit-autofill:focus, .my-input:-webkit-autofill:active {
        -webkit-box-shadow: 0 0 0 1000px #25252d inset !important; -webkit-text-fill-color: #f4f4f5 !important;
        transition: background-color 5000s ease-in-out 0s !important;
    }
    .my-btn {
        flex-shrink: 0 !important; background-color: #6366f1 !important; color: white !important;
        border: none !important; border-radius: 6px !important; padding: 0 20px !important;
        height: 36px !important; font-weight: 600 !important; font-size: 0.9rem !important; cursor: pointer !important;
        margin-left: 10px !important;
    }
    .my-btn:hover { background-color: #4f46e5 !important; }
    
    /* Dropdown tùy chỉnh cho Search */
    .my-select {
        background-color: transparent !important; color: #f4f4f5 !important; border: none !important;
        outline: none !important; height: 36px !important; font-size: 0.9rem !important;
        padding-right: 10px !important; border-right: 1px solid #444 !important; margin-right: 10px !important;
        cursor: pointer;
    }
    .my-select option { background-color: #25252d; color: white; }
</style>

<div class="container-fluid admin-wrapper mt-4 mb-5">
    <h2 class="admin-title">Transactions & Shop Dashboard</h2>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" style="background: rgba(239, 68, 68, 0.15); color: #f87171; border: 1px solid rgba(239, 68, 68, 0.3); border-radius: 8px;">@Model.ErrorMessage</div>
    }

    <div class="custom-tabs">
        <button class="tab-btn tab-active" id="btn-transactions" onclick="switchTab('transactions')">PayOS Deposits</button>
        <button class="tab-btn" id="btn-shop" onclick="switchTab('shop')">Shop Purchases</button>
    </div>

    <div id="tab-transactions" style="display: block;">
        <form method="get" class="mb-4">
            <input type="hidden" name="tab" value="transactions" />
            <div class="my-super-search">
                <svg class="my-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0" />
                </svg>
                <input type="text" name="OrderCode" class="my-input" placeholder="Search by Order Code..." autocomplete="off" value="@Model.OrderCode" />
                
                <select name="StatusFilter" class="my-select">
                    <option value="">All Statuses</option>
                    <option value="Paid" selected="@(Model.StatusFilter == "Paid")">Paid</option>
                    <option value="Pending" selected="@(Model.StatusFilter == "Pending")">Pending</option>
                    <option value="Cancelled" selected="@(Model.StatusFilter == "Cancelled")">Cancelled</option>
                </select>

                <button type="submit" class="my-btn">Filter</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th style="width: 15%;">Order Code</th>
                        <th style="width: 15%;">User</th>
                        <th style="width: 20%;">Package</th>
                        <th style="width: 15%;">Amount (VND)</th>
                        <th style="width: 10%;">Currency</th>
                        <th style="width: 15%;">Date</th>
                        <th style="width: 10%;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tx in Model.Transactions)
                    {
                        <tr>
                            <td style="color: #6b7280; font-family: monospace;">#@tx.OrderCode</td>
                            <td style="color: #fff; font-weight: 600;">@tx.UserName</td>
                            <td style="color: #a1a1aa;">@tx.Name</td>
                            <td style="color: #f87171; font-weight: 700;">@tx.Amount.ToString("N0") ₫</td>
                            <td style="color: #10b981; font-weight: 700;">+@tx.CurrencyAwarded</td>
                            <td style="color: #9ca3af; font-size: 0.85rem;">@tx.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (tx.Status == "Paid") { <span class="badge-custom status-paid">PAID</span> }
                                else if (tx.Status == "Pending") { <span class="badge-custom status-pending">PENDING</span> }
                                else if (tx.Status == "Cancelled") { <span class="badge-custom status-cancelled">CANCELLED</span> }
                                else { <span class="badge-custom status-default">@tx.Status</span> }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div id="tab-shop" style="display: none;">
        <form method="get" class="mb-4">
            <input type="hidden" name="tab" value="shop" />
            <div class="my-super-search" style="max-width: 800px;">
                <svg class="my-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0" />
                </svg>
                
                <input type="text" name="SearchName" class="my-input" placeholder="Search User or Item Name..." autocomplete="off" value="@Model.SearchName" style="border-right: 1px solid #444 !important; padding-right: 10px !important; margin-right: 10px !important;" />
                
                <input type="number" name="Quantity" class="my-input" placeholder="Qty (e.g., 1)" value="@Model.Quantity" style="max-width: 100px; border-right: 1px solid #444 !important; padding-right: 10px !important; margin-right: 10px !important;" />

                <select name="ItemType" class="my-select">
                    <option value="">All Types</option>
                    <option value="Weapon" selected="@(Model.ItemType == "Weapon")">Weapon</option>
                    <option value="Character" selected="@(Model.ItemType == "Character")">Character</option>
                    <option value="Consumable" selected="@(Model.ItemType == "Consumable")">Consumable</option>
                </select>

                <button type="submit" class="my-btn">Filter</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th style="width: 20%;">User</th>
                        <th style="width: 25%;">Item Purchased</th>
                        <th style="width: 10%;">Qty</th>
                        <th style="width: 15%;">Pay Type</th>
                        <th style="width: 15%;">Total Spent</th>
                        <th style="width: 15%;">Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var purchase in Model.ShopPurchases)
                    {
                        <tr>
                            <td style="color: #fff; font-weight: 600;">@purchase.UserName</td>
                            <td style="color: #f4f4f5; font-weight: 700;">@purchase.ShopItemName</td>
                            <td style="color: #a1a1aa;">x @purchase.Quantity</td>
                            <td><span class="badge-custom status-default">@purchase.PaymentType</span></td>
                            <td style="color: #fca5a5; font-weight: 700;">- @purchase.AmountPaid</td>
                            <td style="color: #9ca3af; font-size: 0.85rem;">@purchase.PurchaseDate.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const urlParams = new URLSearchParams(window.location.search);
            const activeTab = urlParams.get('tab');
            if (activeTab === 'shop') {
                switchTab('shop');
            }
        });

        function switchTab(tabName) {
            document.getElementById('tab-transactions').style.display = 'none';
            document.getElementById('tab-shop').style.display = 'none';
            document.getElementById('btn-transactions').classList.remove('tab-active');
            document.getElementById('btn-shop').classList.remove('tab-active');
            
            if(tabName === 'transactions') {
                document.getElementById('tab-transactions').style.display = 'block';
                document.getElementById('btn-transactions').classList.add('tab-active');
            } else {
                document.getElementById('tab-shop').style.display = 'block';
                document.getElementById('btn-shop').classList.add('tab-active');
            }
        }
    </script>
}